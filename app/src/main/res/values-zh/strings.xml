    <string name="view_logs">查看日志</string>
    <string name="share_logs">分享</string>
    <string name="clear_logs">清除</string>
    <string name="no_logs_to_share">没有可分享的日志</string>
    <string name="no_logs_to_view">暂无日志</string>
    <string name="logs_cleared">日志已清除</string>
    <string name="debug_logs_title">调试日志</string>

    <!-- Footer -->
    <string name="open_source_message">免费、开源、无广告，只为保护你的隐私。\n如果觉得有用，欢迎捐赠支持后续开发。</string>

    <!-- Accessibility Service -->
    <string name="accessibility_service_label">隐私开关 - 侧键支持</string>
    <string name="accessibility_service_description">让隐私开关能够更早检测到侧键/电源键锁屏，从而使摄像头和麦克风隐私功能在"立即锁定"模式下也能正常工作。该服务不会读取屏幕内容或密码，仅用于检测锁屏界面的出现，以便在键盘锁完全启动前触发隐私操作。</string>
</resources>
